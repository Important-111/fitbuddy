/* ===== FitBuddy 设计系统 ===== */
page {
  --primary: #FF6B35;
  --primary-light: rgba(255,107,53,0.08);
  --primary-hover: #E55A2B;
  --accent: #36CFC9;
  --accent-light: rgba(54,207,201,0.08);
  --bg: #F9FAFB;
  --card: #FFFFFF;
  --text-primary: #1F2937;
  --text-secondary: #6B7280;
  --text-tertiary: #9CA3AF;
  --border: #E5E7EB;
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;

  margin: 0; padding: 0;
  box-sizing: border-box;
  background: #F0F2F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ===== 通用容器 ===== */
.page-container {
  min-height: 100vh;
  background: var(--bg);
  position: relative;
  overflow-x: hidden;
  padding-bottom: 80px;
}

.page-container.no-tab {
  padding-bottom: 0;
}

/* ===== 顶部导航 ===== */
.top-bar {
  padding: 14px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--card);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}
.top-bar.justify-between { justify-content: space-between; }
.top-bar-title { font-size: 17px; font-weight: 600; color: var(--text-primary); }
.btn-back {
  width: 36px; height: 36px; border: none; background: none;
  display: flex; align-items: center; justify-content: center;
  border-radius: 8px;
  color: var(--text-primary);
}

/* ===== 按钮 ===== */
.btn-primary {
  width: 100%; height: 50px; background: var(--primary); color: #FFF;
  border: none; border-radius: 12px; font-size: 16px; font-weight: 600;
  font-family: inherit;
}
.btn-primary:active { opacity: 0.9; }

.btn-secondary {
  flex: 1; height: 44px; background: var(--bg); color: var(--text-primary);
  border: 1px solid var(--border); border-radius: 10px; font-size: 15px;
  font-family: inherit;
}

.btn-outline {
  flex: 1; height: 48px; border: 2px solid var(--primary); border-radius: 12px;
  background: var(--card); color: var(--primary); font-size: 15px; font-weight: 600;
  font-family: inherit;
}

.btn-confirm {
  flex: 1; height: 44px; background: var(--primary); color: #FFF;
  border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
  font-family: inherit;
}

.btn-start {
  width: 100%; height: 46px; background: var(--primary); color: #FFF;
  border: none; border-radius: 10px; font-size: 15px; font-weight: 600;
  font-family: inherit;
}

.btn-submit {
  width: 100%; height: 48px; background: var(--primary); color: #FFF;
  border: none; border-radius: 12px; font-size: 16px; font-weight: 600;
  font-family: inherit;
}

.btn-sm {
  height: 34px; padding: 0 16px; font-size: 12px; border-radius: 8px;
}

/* ===== 分类标题 ===== */
.section-title {
  font-size: 16px; font-weight: 600; color: var(--text-primary);
  margin-bottom: 12px; display: flex; align-items: center; gap: 8px;
}
.section-title::before {
  content: ''; width: 3px; height: 14px; background: var(--primary); border-radius: 2px;
  flex-shrink: 0;
}
.section-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;
}

/* ===== 表单 ===== */
.form-group { margin-bottom: 18px; }
.form-label { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; display: block; }
.form-input {
  width: 100%; height: 48px; border: 1px solid var(--border); border-radius: 10px;
  padding: 0 14px; font-size: 15px; color: var(--text-primary); background: var(--card);
  font-family: inherit; box-sizing: border-box;
}
.form-row { display: flex; gap: 12px; }
.form-row .form-group { flex: 1; }
.form-tip { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }

/* 性别选择 */
.gender-group { display: flex; gap: 12px; }
.gender-option {
  flex: 1; height: 48px; border: 2px solid var(--border); border-radius: 10px;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  font-size: 15px; color: var(--text-secondary);
  background: var(--card);
}
.gender-option.selected { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }

/* Chip 选择 */
.option-group { display: flex; flex-wrap: wrap; gap: 8px; }
.option-chip {
  padding: 10px 16px; border: 2px solid var(--border); border-radius: 10px;
  font-size: 14px; color: var(--text-secondary);
  background: var(--card);
}
.option-chip.selected { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
.equip-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.equip-chip {
  padding: 12px; border: 2px solid var(--border); border-radius: 10px;
  font-size: 13px; color: var(--text-secondary);
  background: var(--card); text-align: center;
}
.equip-chip.selected { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
.days-group { display: flex; gap: 8px; flex-wrap: wrap; }
.day-chip {
  width: 42px; height: 42px; border: 2px solid var(--border); border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 600; color: var(--text-secondary);
  background: var(--card);
}
.day-chip.selected { border-color: var(--primary); color: #FFF; background: var(--primary); }

/* ===== 底部 Tab ===== */
.bottom-tab {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--card); border-top: 1px solid var(--border);
  display: flex; padding: 6px 0 12px; z-index: 100;
}
.tab-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  padding: 6px 0; color: var(--text-secondary); font-size: 10px;
}
.tab-item.active { color: var(--primary); }
.tab-icon { width: 22px; height: 22px; margin-bottom: 3px; }

/* ===== Toast ===== */
.toast-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none; z-index: 9999;
}
.toast-content {
  background: rgba(31,41,55,0.95); color: #FFF;
  padding: 14px 22px; border-radius: 12px; font-size: 14px;
  max-width: 80%; text-align: center;
}

/* ===== 安全提醒 ===== */
.health-warning {
  background: #FEF2F2; border: 1px solid #FECACA; border-radius: 10px;
  padding: 12px 14px; margin-bottom: 18px;
}
.health-warning text { font-size: 12px; color: #B91C1C; line-height: 1.5; }

/* ===== 欢迎页 ===== */
.welcome-hero {
  padding: 60px 24px 80px; text-align: center;
  position: relative; overflow: hidden;
}
.hero-icon {
  width: 80px; height: 80px;
  border-radius: 24px; margin: 0 auto 20px;
  display: flex; align-items: center; justify-content: center;
}
.hero-title { font-size: 28px; font-weight: 700; color: #FFF; margin-bottom: 8px; }
.hero-subtitle { font-size: 14px; color: rgba(255,255,255,0.85); }
.profile-section { padding: 24px; margin-top: -40px; position: relative; z-index: 2; }
.profile-card { background: var(--card); border-radius: 12px; padding: 20px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); border: 1px solid var(--border); }
.profile-header-mod { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px dashed var(--border); }
.profile-title { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 700; color: var(--text-primary); }
.profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 20px; }
.profile-item { display: flex; flex-direction: column; gap: 4px; }
.profile-item.full { grid-column: span 2; }
.profile-label { font-size: 12px; color: var(--text-tertiary); }
.profile-value { font-size: 15px; color: var(--text-primary); font-weight: 600; display: flex; align-items: center; gap: 6px; }
.features-section { padding: 16px 24px 24px; }
.features-section-title { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; }
.feature-card {
  background: var(--card); border-radius: 12px; padding: 14px; margin-bottom: 10px;
  display: flex; align-items: center; gap: 14px; border: 1px solid var(--border);
}
.feature-icon { width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0; }
.feature-text h3 { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 2px; }
.feature-text p { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }
.bottom-cta { padding: 8px 24px 32px; }
.privacy-note { text-align: center; font-size: 12px; color: var(--text-secondary); margin-top: 12px; }
.section-title-inline { font-size: 20px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
.section-desc { font-size: 13px; color: var(--text-secondary); margin-bottom: 20px; line-height: 1.5; }
.form-section { padding: 20px 24px; }

/* ===== 训练目标页 ===== */
.goal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.goal-card { padding: 16px 14px; border: 2px solid var(--border); border-radius: 12px; background: var(--card); text-align: center; }
.goal-card.selected { border-color: var(--primary); background: var(--primary-light); }
.goal-icon { font-size: 28px; margin-bottom: 8px; }
.goal-name { font-size: 14px; font-weight: 600; color: var(--text-primary); }

/* ===== 仪表盘 ===== */
.top-greeting { font-size: 13px; color: var(--text-secondary); }
.top-name { font-size: 18px; font-weight: 700; color: var(--text-primary); }
.top-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--primary-light); }
.streak-banner { margin: 16px 20px; border-radius: 14px; padding: 20px; color: #FFF; }
.streak-header { display: flex; align-items: center; justify-content: space-between; }
.streak-fire { font-size: 32px; }
.streak-days { font-size: 36px; font-weight: 700; }
.streak-label { font-size: 13px; opacity: 0.9; }
.streak-stats { display: flex; gap: 20px; margin-top: 14px; }
.streak-stat { text-align: center; }
.streak-stat-val { font-size: 16px; font-weight: 700; }
.streak-stat-lbl { font-size: 11px; opacity: 0.8; }
.today-section { padding: 0 20px; margin-bottom: 20px; }
.today-card { background: var(--card); border-radius: 14px; padding: 20px; border: 1px solid var(--border); }
.today-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
.today-day { font-size: 15px; font-weight: 600; color: var(--text-primary); }
.today-type { font-size: 12px; color: var(--primary); background: var(--primary-light); padding: 4px 10px; border-radius: 6px; }
.today-goal { font-size: 13px; color: var(--text-secondary); margin-bottom: 14px; }
.today-meta { display: flex; gap: 20px; margin-bottom: 16px; }
.today-meta-item { text-align: center; }
.today-meta-val { font-size: 16px; font-weight: 700; color: var(--text-primary); }
.today-meta-lbl { font-size: 11px; color: var(--text-secondary); }
.quick-actions { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 10px; padding: 0 20px; margin-bottom: 20px; }
.quick-action { background: var(--card); border-radius: 12px; padding: 14px 8px; text-align: center; border: 1px solid var(--border); }
.quick-action-icon { font-size: 24px; margin-bottom: 6px; }
.quick-action-text { font-size: 11px; color: var(--text-secondary); }
.progress-section { padding: 0 20px; margin-bottom: 20px; }
.progress-card { background: var(--card); border-radius: 14px; padding: 18px; border: 1px solid var(--border); }

/* ===== 训练计划 ===== */
.month-goal-card { margin: 16px 20px; border-radius: 16px; padding: 22px; color: #FFF; box-shadow: 0 4px 20px rgba(255,107,53,0.25); text-shadow: 0 1px 3px rgba(0,0,0,0.12); }
.month-goal-title { font-size: 14px; opacity: 0.9; }
.month-goal-main { font-size: 22px; font-weight: 700; margin: 6px 0; line-height: 1.4; }
.month-goal-sub { font-size: 13px; opacity: 0.85; }
.week-tabs { display: flex; padding: 0 20px; gap: 6px; margin-bottom: 16px; overflow-x: auto; }
.week-tab { padding: 8px 16px; border-radius: 20px; font-size: 13px; border: 1px solid var(--border); background: var(--card); color: var(--text-secondary); white-space: nowrap; }
.week-tab.active { background: var(--primary); color: #FFF; border-color: var(--primary); }
.week-schedule { padding: 0 20px; }
.day-card { background: var(--card); border-radius: 12px; padding: 16px; margin-bottom: 10px; border: 1px solid var(--border); display: flex; align-items: center; gap: 14px; position: relative; }
.day-card::before { content: ''; position: absolute; left: 0; top: 8px; bottom: 8px; width: 3px; border-radius: 0 3px 3px 0; background: transparent; transition: background 0.2s; }
.day-card.today { border-color: var(--primary); background: rgba(255,107,53,0.05); }
.day-card.today::before { background: var(--primary); }
.day-card.done .day-num { background: var(--success); color: #FFF; }
.day-card.rest .day-num { background: #E5E7EB; color: var(--text-secondary); }
.day-num { width: 44px; height: 44px; border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--border); color: var(--text-secondary); flex-shrink: 0; }
.day-card.today .day-num { background: var(--primary); color: #FFF; }
.day-num-name { font-size: 13px; font-weight: 600; }
.day-num-date { font-size: 10px; }
.day-info { flex: 1; }
.day-type { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; }
.day-desc { font-size: 12px; color: var(--text-secondary); }
.day-status { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; }
.status-todo { background: var(--primary-light); color: var(--primary); }
.status-done { background: rgba(16,185,129,0.1); color: var(--success); }

/* ===== 每日训练 ===== */
.workout-header { margin: 16px 20px; border-radius: 14px; padding: 20px; color: #FFF; }
.workout-header h2 { font-size: 20px; font-weight: 700; }
.workout-header p { font-size: 13px; opacity: 0.9; margin-top: 4px; }
.workout-meta { display: flex; gap: 20px; margin-top: 14px; }
.workout-meta-item { text-align: center; }
.workout-meta-val { font-size: 18px; font-weight: 700; }
.workout-meta-lbl { font-size: 11px; opacity: 0.8; }
.phase-section { padding: 0 20px; margin-bottom: 16px; }
.phase-title { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.exercise-card { background: var(--card); border-radius: 12px; padding: 16px; margin-bottom: 10px; border: 1px solid var(--border); display: flex; gap: 14px; align-items: flex-start; }
.exercise-card.completed { border-color: var(--success); }
.exercise-num { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700; flex-shrink: 0; background: var(--primary-light); color: var(--primary); }
.exercise-info { flex: 1; }
.exercise-name { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 4px; }
.exercise-detail { font-size: 13px; color: var(--text-secondary); }

/* ===== 动作说明 ===== */
.exercise-hero { margin: 16px 20px; border-radius: 14px; height: 180px; display: flex; align-items: center; justify-content: center; color: #FFF; font-size: 48px; }
.exercise-main-name { font-size: 22px; font-weight: 700; color: var(--text-primary); }
.exercise-tags { display: flex; gap: 8px; margin-top: 10px; }
.exercise-tag { padding: 5px 12px; border-radius: 20px; font-size: 12px; }
.info-section { padding: 0 20px; margin-bottom: 16px; }
.info-title { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
.info-card { background: var(--card); border-radius: 12px; padding: 16px; border: 1px solid var(--border); margin-bottom: 8px; }
.info-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #F3F4F6; }
.info-row:last-child { border-bottom: none; }

/* ===== 打卡 ===== */
.checkin-hero { margin: 16px 20px; border-radius: 14px; padding: 24px; text-align: center; color: #FFF; }
.checkin-hero-emoji { font-size: 48px; margin-bottom: 8px; }
.checkin-hero h2 { font-size: 20px; font-weight: 700; }
.checkin-hero p { font-size: 13px; opacity: 0.9; margin-top: 4px; }
.rating-section { padding: 0 20px; margin-bottom: 16px; }
.rating-label { font-size: 15px; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; }
.rating-stars { display: flex; gap: 10px; justify-content: center; }
.rating-star { width: 48px; height: 48px; border-radius: 12px; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 22px; background: var(--card); }
.rating-star.selected { border-color: var(--primary); background: var(--primary-light); }

/* ===== 进度追踪 ===== */
.overview-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; padding: 16px 20px; }
.overview-card { background: var(--card); border-radius: 14px; padding: 16px; border: 1px solid var(--border); text-align: center; }
.overview-val { font-size: 24px; font-weight: 700; color: var(--primary); }
.overview-lbl { font-size: 12px; color: var(--text-secondary); margin-top: 4px; }
.chart-section { padding: 0 20px; margin-bottom: 16px; }
.chart-card { background: var(--card); border-radius: 14px; padding: 20px; border: 1px solid var(--border); }
.chart-title { font-size: 15px; font-weight: 600; color: var(--text-primary); }
.chart-placeholder { height: 160px; background: #F9FAFB; border-radius: 8px; display: flex; align-items: flex-end; justify-content: space-around; padding: 20px 10px; border: 1px dashed var(--border); }
.chart-bar { width: 28px; border-radius: 6px 6px 0 0; background: var(--primary); }
.chart-bar.accent { background: var(--accent); }
.chart-bar-label { font-size: 10px; color: var(--text-secondary); }
.period-tabs { display: flex; gap: 6px; padding: 0 20px; margin-bottom: 16px; }
.period-tab { flex: 1; height: 36px; border-radius: 10px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 13px; background: var(--card); color: var(--text-secondary); }
.period-tab.active { background: var(--primary); color: #FFF; border-color: var(--primary); }
.filter-tabs { display: flex; gap: 6px; padding: 0 20px; margin-bottom: 12px; }
.filter-tab { padding: 6px 16px; border-radius: 16px; font-size: 12px; border: 1px solid var(--border); background: var(--card); color: var(--text-secondary); }
.filter-tab.active { background: var(--primary); color: #FFF; border-color: var(--primary); }

/* ===== 饮食 ===== */
.nutri-banner { margin: 16px 20px; border-radius: 14px; padding: 20px; color: #FFF; }
.nutri-banner h2 { font-size: 18px; font-weight: 700; margin-bottom: 12px; }
.nutri-row { display: flex; justify-content: space-around; }
.nutri-item { text-align: center; }
.nutri-val { font-size: 20px; font-weight: 700; }
.nutri-lbl { font-size: 11px; opacity: 0.85; margin-top: 2px; }
.meal-section { padding: 0 20px; margin-bottom: 16px; }
.meal-card { background: var(--card); border-radius: 14px; padding: 16px; margin-bottom: 10px; border: 1px solid var(--border); }
.meal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.meal-time { font-size: 14px; font-weight: 600; color: var(--text-primary); display: flex; align-items: center; gap: 8px; }
.meal-emoji { font-size: 18px; }
.meal-cal { font-size: 13px; color: var(--primary); font-weight: 600; background: var(--primary-light); padding: 4px 10px; border-radius: 6px; }
.meal-items { display: flex; flex-wrap: wrap; gap: 6px; }
.meal-item { padding: 6px 12px; background: #F9FAFB; border-radius: 8px; font-size: 12px; color: var(--text-primary); }
.macro-section { padding: 0 20px; margin-bottom: 16px; }
.macro-card { background: var(--card); border-radius: 14px; padding: 18px; border: 1px solid var(--border); }
.macro-row { display: flex; align-items: center; margin-bottom: 14px; }
.macro-row:last-child { margin-bottom: 0; }
.macro-label { min-width: 60px; font-size: 13px; color: var(--text-secondary); }
.macro-bar-wrap { flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; margin: 0 10px; }
.macro-bar { height: 100%; border-radius: 4px; }
.macro-bar.protein { background: var(--primary); }
.macro-bar.carb { background: var(--warning); }
.macro-bar.fat { background: var(--accent); }

/* ===== 个人中心 ===== */
.profile-header-card { margin: 16px 20px; border-radius: 16px; padding: 24px; color: #FFF; display: flex; align-items: center; gap: 16px; }
.profile-avatar { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 32px; flex-shrink: 0; }
.profile-name { font-size: 20px; font-weight: 700; }
.profile-goal { font-size: 13px; opacity: 0.85; margin-top: 2px; }
.profile-tags { display: flex; gap: 6px; margin-top: 8px; }
.profile-tag { padding: 3px 10px; border-radius: 20px; font-size: 11px; background: rgba(255,255,255,0.2); }
.menu-section { padding: 0 20px; margin-bottom: 16px; }
.menu-card { background: var(--card); border-radius: 14px; border: 1px solid var(--border); overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 14px 16px; border-bottom: 1px solid var(--border); }
.menu-item:last-child { border-bottom: none; }
.menu-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; margin-right: 12px; }
.menu-text { flex: 1; }
.menu-title { font-size: 14px; color: var(--text-primary); }
.menu-desc { font-size: 11px; color: var(--text-secondary); }
.version-text { text-align: center; font-size: 11px; color: var(--text-secondary); margin-bottom: 16px; }

/* ===== Modal ===== */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 1000;
  display: flex; align-items: center; justify-content: center; padding: 24px;
}
.modal {
  background: var(--card); border-radius: 16px; width: 100%; max-width: 380px;
}
.modal-header {
  padding: 20px 20px 12px; display: flex; align-items: center;
  justify-content: space-between; border-bottom: 1px solid var(--border);
}
.modal-title { font-size: 16px; font-weight: 700; color: var(--text-primary); }
.modal-close { width: 28px; height: 28px; border-radius: 50%; font-size: 16px; }
.modal-body { padding: 20px; max-height: 60vh; overflow-y: auto; }
.modal-footer { padding: 12px 20px 20px; display: flex; gap: 12px; }

/* ===== 进度条 ===== */
.progress-bar-bg { height: 4px; background: var(--border); border-radius: 2px; margin-top: 8px; }
.progress-bar-fill { height: 100%; background: var(--primary); border-radius: 2px; }
