<view class="page-container no-tab">
  <!-- 顶部导航 -->
  <view class="top-bar">
    <view class="btn-back" bindtap="goBack">
      <text style="font-size:20px;">‹</text>
    </view>
    <text class="top-bar-title">建立你的档案</text>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar-wrap">
    <view class="progress-steps">
      <view class="progress-step active">1</view>
      <view class="progress-step">2</view>
      <view class="progress-step">3</view>
    </view>
    <view class="progress-bar-bg">
      <view class="progress-bar-fill" style="width:33%"></view>
    </view>
    <text class="progress-label">步骤 1/3 · 基础身体信息</text>
  </view>

  <!-- 表单 -->
  <view class="form-section">
    <text class="section-title-inline">基础信息</text>
    <text class="section-desc">请如实填写以下信息，这将帮助我们为你制定最合适的训练计划</text>

    <!-- 性别 -->
    <view class="form-group">
      <text class="form-label">性别</text>
      <view class="gender-group">
        <view class="gender-option {{gender === 'male' ? 'selected' : ''}}" bindtap="selectGender" data-gender="male">
          <image wx:if="{{gender === 'male'}}" style="width:22px;height:22px;display:block;" src="data:image/svg+xml;base64,"/>
          <image wx:else style="width:22px;height:22px;display:block;" src="data:image/svg+xml;base64,"/>
          <text>男</text>
        </view>
        <view class="gender-option {{gender === 'female' ? 'selected' : ''}}" bindtap="selectGender" data-gender="female">
          <image wx:if="{{gender === 'female'}}" style="width:22px;height:22px;display:block;" src="data:image/svg+xml;base64,"/>
          <image wx:else style="width:22px;height:22px;display:block;" src="data:image/svg+xml;base64,"/>
          <text>女</text>
        </view>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="form-group">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="如何称呼你" value="{{nickname}}" bindinput="onInput" data-field="nickname" />
    </view>

    <!-- 年龄 + 身高 -->
    <view class="form-row">
      <view class="form-group">
        <text class="form-label">年龄</text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="25" value="{{age}}" bindinput="onInput" data-field="age" />
          <text class="input-unit">岁</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">身高</text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="170" value="{{height}}" bindinput="onCalcBMI" data-field="height" />
          <text class="input-unit">cm</text>
        </view>
      </view>
    </view>

    <!-- 体重 + 目标体重 -->
    <view class="form-row">
      <view class="form-group">
        <text class="form-label">当前体重</text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="70" value="{{weight}}" bindinput="onCalcBMI" data-field="weight" />
          <text class="input-unit">kg</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">目标体重</text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="60" value="{{targetWeight}}" bindinput="onInput" data-field="targetWeight" />
          <text class="input-unit">kg</text>
        </view>
      </view>
    </view>

    <!-- BMI 自动计算 -->
    <view class="form-group">
      <text class="form-label">BMI <text style="font-size:12px;color:var(--text-secondary);font-weight:400;">（自动计算）</text></text>
      <view class="bmi-display">
        <text style="font-size:14px;color:var(--text-secondary);">身体质量指数</text>
        <view style="text-align:right;">
          <text class="bmi-value">{{bmiValue}}</text>
          <text class="bmi-category">{{bmiCategory}}</text>
        </view>
      </view>
    </view>

    <!-- 腰围 + 臀围 -->
    <view class="form-row">
      <view class="form-group">
        <text class="form-label">腰围 <text style="font-size:12px;color:var(--text-secondary);font-weight:400;">（选填）</text></text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="80" value="{{waist}}" bindinput="onInput" data-field="waist" />
          <text class="input-unit">cm</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">臀围 <text style="font-size:12px;color:var(--text-secondary);font-weight:400;">（选填）</text></text>
        <view class="input-with-unit">
          <input class="form-input" type="number" placeholder="95" value="{{hip}}" bindinput="onInput" data-field="hip" />
          <text class="input-unit">cm</text>
        </view>
      </view>
    </view>

    <!-- 体脂率 -->
    <view class="form-group">
      <text class="form-label">体脂率 <text style="font-size:12px;color:var(--text-secondary);font-weight:400;">（不知道可跳过）</text></text>
      <view class="input-with-unit">
        <input class="form-input" type="number" placeholder="25" value="{{bodyFat}}" bindinput="onInput" data-field="bodyFat" />
        <text class="input-unit">%</text>
      </view>
      <text class="form-tip">可使用体脂秤测量，没有可跳过</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-nav">
    <button class="btn-primary" bindtap="saveBasicInfo">下一步：选择训练目标</button>
  </view>
</view>
