/* Basic info page styles */
.progress-bar-wrap {
  padding: 16px 24px;
  background: var(--card);
}
.progress-steps {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}
.progress-step {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  background: var(--border);
  color: var(--text-secondary);
}
.progress-step.active {
  background: var(--primary);
  color: #FFF;
}
.progress-step.done {
  background: var(--success);
  color: #FFF;
}
.progress-label {
  text-align: center;
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 8px;
}
.form-section {
  padding: 20px 24px;
}
.section-title-inline {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
  display: block;
}
.section-desc {
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 20px;
  line-height: 1.5;
  display: block;
}
.input-with-unit {
  position: relative;
}
.input-with-unit .form-input {
  padding-right: 50px;
}
.input-unit {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14px;
  color: var(--text-secondary);
}
.bmi-display {
  background: var(--primary-light);
  border-radius: 10px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 4px;
}
.bmi-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--primary);
  display: block;
}
.bmi-category {
  font-size: 12px;
  color: var(--text-secondary);
  padding: 4px 8px;
  background: var(--card);
  border-radius: 6px;
  display: inline-block;
  margin-top: 4px;
}
.bottom-nav {
  padding: 16px 24px 32px;
  background: var(--card);
  border-top: 1px solid var(--border);
}
