<view class="page-container no-tab">
  <!-- 顶部栏 with 返回按钮 -->
  <view class="top-bar">
    <button class="btn-back" bindtap="navigateBack">
      <text style="font-size:20px;line-height:1;">‹</text>
    </button>
    <text class="top-bar-title">动作详解</text>
  </view>

  <!-- 动作主图区 -->
  <view class="exercise-hero" style="background:linear-gradient(135deg,#FF6B35,#FF8F65);">
    {{exerciseEmoji}}
  </view>

  <!-- 动作名称与标签 -->
  <view class="exercise-name-section">
    <view class="exercise-main-name">{{exerciseName}}</view>
    <view class="exercise-eng-name">{{exerciseEng}}</view>
    <view class="exercise-tags">
      <text class="exercise-tag tag-level">🏆{{levelLabel}}</text>
      <text class="exercise-tag tag-muscle">💪{{muscleLabel}}</text>
      <text class="exercise-tag tag-type">🎯{{typeLabel}}</text>
    </view>
  </view>

  <!-- 动作信息卡 -->
  <view class="info-section">
    <view class="info-title">动作概要</view>
    <view class="info-card">
      <view wx:for="{{infoRows}}" wx:key="key" class="info-row">
        <text class="info-key">{{item.key}}</text>
        <text class="info-value" style="{{item.highlight ? 'color:var(--primary);font-weight:600;' : ''}}">{{item.value}}</text>
      </view>
    </view>
  </view>

  <!-- 目标肌群 -->
  <view class="info-section">
    <view class="info-title">目标肌群</view>
    <view class="muscle-group">
      <text wx:for="{{muscleTags}}" wx:key="*this" class="muscle-tag">{{item}}</text>
    </view>
  </view>

  <!-- 动作要点 -->
  <view class="info-section">
    <view class="info-title">动作要点</view>
    <view class="info-card">
      <view class="points-list">
        <view wx:for="{{steps}}" wx:key="num">
          <text class="point-num">{{item.num}}</text>
          <text>{{item.text}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 呼吸方式 -->
  <view class="info-section">
    <view class="info-title">呼吸方式</view>
    <view class="info-card">
      <view wx:for="{{breathSteps}}" wx:key="phase" class="breath-row">
        <text class="breath-phase">💪 {{item.phase}}</text>
        <text class="breath-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 常见错误 -->
  <view class="info-section">
    <view class="info-title">常见错误</view>
    <view class="info-card">
      <view class="points-list caution-list">
        <view wx:for="{{cautions}}" wx:key="title" class="caution-item">
          <text class="point-num">!</text>
          <view class="caution-body">
            <text class="caution-title">{{item.title}}</text>
            <text class="caution-text">{{item.text}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 视频教程推荐 -->
  <view class="video-section">
    <view class="info-title">视频教程推荐</view>
    <view wx:for="{{videos}}" wx:key="platform" class="video-card">
      <text class="video-platform {{item.platformClass}}">{{item.platform}}</text>
      <view class="video-info">
        <view class="video-title">{{item.title}}</view>
        <view class="video-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>
