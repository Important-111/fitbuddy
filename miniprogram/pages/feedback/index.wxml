<view class="page-container">
  <!-- 顶部栏 -->
  <view class="top-bar">
    <view class="nav-back" bindtap="navigateBack">
      <text style="font-size:22px;font-weight:300;line-height:1;color:var(--text-primary);margin-top:-2px;">‹</text>
    </view>
    <text class="top-bar-title" style="flex:1;text-align:center;margin-right:36px;">意见反馈</text>
  </view>

  <!-- 反馈类型 -->
  <view class="section-wrap">
    <view class="section-title">反馈类型</view>
    <view class="type-grid">
      <view
        wx:for="{{feedbackTypes}}"
        wx:key="value"
        class="type-chip {{form.type === item.value ? 'selected' : ''}}"
        bindtap="onTypeSelect"
        data-value="{{item.value}}"
      >
        <text class="type-emoji">{{item.emoji}}</text>
        <text class="type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 反馈内容 -->
  <view class="section-wrap">
    <view class="section-title">反馈内容 <text style="color:var(--danger);font-size:12px;">*</text></view>
    <view class="textarea-wrap">
      <textarea
        class="feedback-textarea"
        placeholder="请详细描述你的反馈，至少 10 个字～"
        placeholder-class="ph"
        maxlength="500"
        value="{{form.content}}"
        bindinput="onContentInput"
      />
      <view class="char-count">{{form.content.length}}/500</view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section-wrap">
    <view class="section-title">联系方式（可选）</view>
    <view class="input-wrap">
      <input
        class="feedback-input"
        placeholder="微信号 / 邮箱，方便我们回复你"
        placeholder-class="ph"
        maxlength="50"
        value="{{form.contact}}"
        bindinput="onContactInput"
      />
    </view>
    <view class="hint-text">填写后我们可在需要时与你确认细节</view>
  </view>

  <!-- 提示 -->
  <view class="info-tip">
    <text class="info-tip-icon">💡</text>
    <view class="info-tip-text">
      <text style="font-weight:600;display:block;margin-bottom:2px;">你的反馈对我们很重要</text>
      <text style="font-size:12px;color:var(--text-secondary);display:block;line-height:1.5;">所有反馈都会被认真阅读，常见问题会优先在下个版本改进～</text>
    </view>
  </view>

  <!-- 历史反馈 -->
  <view wx:if="{{history.length > 0}}" class="section-wrap">
    <view class="section-title">我的反馈（{{history.length}}）</view>
    <view class="history-list">
      <view wx:for="{{history}}" wx:key="ts" class="history-item">
        <view class="history-header">
          <text class="history-type">{{item.typeLabel}}</text>
          <text class="history-status status-{{item.status}}">{{item.statusLabel}}</text>
        </view>
        <text class="history-content">{{item.content}}</text>
        <text class="history-time">{{item.timeLabel}}</text>
        <view wx:if="{{item.adminReply}}" class="history-reply">
          <text class="reply-label">开发者回复：</text>
          <text class="reply-text">{{item.adminReply}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">{{submitting ? '提交中...' : '提交反馈'}}</button>
  </view>
</view>
