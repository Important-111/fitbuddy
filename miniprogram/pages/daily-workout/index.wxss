/* 每日训练详情页 - 补充样式 */

.exercise-sets {
  font-size: 13px;
  color: var(--primary);
  font-weight: 600;
  margin-top: 4px;
}

.exercise-rest {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
}

.exercise-arrow {
  display: flex;
  align-items: center;
  color: var(--text-tertiary);
  font-size: 18px;
  padding-left: 8px;
}

.phase-icon {
  font-size: 18px;
}

.phase-icon.warmup {
  color: #FF6B35;
}

.phase-icon.main {
  color: #10B981;
}

.phase-icon.stretch {
  color: #36CFC9;
}

.total-calories {
  display: flex;
  justify-content: space-around;
  padding: 16px 20px;
  background: var(--card);
  margin: 0 20px 16px;
  border-radius: 14px;
  border: 1px solid var(--border);
}

.total-item {
  text-align: center;
}

.total-item-val {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary);
}

.total-item-lbl {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 2px;
}

.nav-back {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 8px;
  flex-shrink: 0;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 20px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: var(--card);
  border-top: 1px solid var(--border);
  display: flex;
  gap: 12px;
  align-items: stretch;
}
.bottom-bar .btn-outline,
.bottom-bar .btn-primary {
  flex: 1;
  min-width: 0;
  width: auto;
  max-width: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  text-align: center;
}

.stretch-card {
  background: var(--card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 10px;
  border: 1px solid var(--border);
  display: flex;
  gap: 14px;
  align-items: center;
}

.flow-arrow {
  text-align: center;
  font-size: 20px;
  color: var(--text-tertiary);
  padding: 4px 0;
}

/* === Countdown Timer === */
.exercise-timer {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 6px 8px;
  border-radius: 10px;
  background: rgba(0,0,0,0.04);
  border: 1px solid var(--border);
  min-width: 78px;
}
.exercise-card.completed .exercise-timer {
  opacity: 0.55;
}
.exercise-timer.running {
  background: rgba(255,107,53,0.08);
  border-color: var(--primary);
}
.exercise-timer.finished {
  background: rgba(16,185,129,0.12);
  border-color: #10B981;
}
.exercise-timer.finished .timer-display {
  color: #10B981;
}
.timer-display {
  font-size: 16px;
  font-weight: 700;
  color: var(--primary);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.3px;
  line-height: 1.1;
}
.timer-controls {
  display: flex;
  gap: 4px;
  align-items: center;
}
.timer-btn {
  height: 22px;
  min-width: 22px;
  padding: 0 6px;
  border-radius: 6px;
  background: var(--card);
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.timer-btn.adjust {
  font-size: 10px;
}
.stretch-card .exercise-timer {
  min-width: 70px;
}
