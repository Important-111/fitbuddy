.agreement-page {
  width: 100%;
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.top-bar {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F2F5;
  position: sticky;
  top: 0;
  z-index: 10;
}

.btn-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #1F2937;
  border-bottom: 4rpx solid #1F2937;
  transform: rotate(45deg);
}

.top-bar-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  text-align: center;
  padding-right: 60rpx;
}

.content {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
}

.update-time {
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
  margin-bottom: 8rpx;
}

.notice-box {
  background: #FFF7ED;
  border: 1rpx solid #FDE68A;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400E;
  margin-bottom: 12rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #A16207;
  line-height: 1.6;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B35;
}

.paragraph {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.bold {
  font-weight: 600;
  color: #1F2937;
}

.code {
  font-family: 'Courier New', monospace;
  background: #F3F4F6;
  color: #FF6B35;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.info-table {
  background: #F9FAFB;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E5E7EB;
  margin: 16rpx 0;
}

.info-row {
  display: flex;
  border-bottom: 1rpx solid #E5E7EB;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row-head {
  background: #FF6B35;
}

.info-row-head .info-cell {
  color: #FFFFFF;
  font-weight: 600;
}

.info-cell {
  padding: 16rpx;
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.5;
}

.cell-type {
  flex: 1.2;
}

.cell-purpose {
  flex: 1.5;
}

.cell-action {
  flex: 1.3;
}

.footer-spacing {
  height: 80rpx;
}
