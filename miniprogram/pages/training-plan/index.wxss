/* 训练计划页 - 补充样式 */

/* ===== 月目标卡片增强 ===== */
.month-goal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.month-goal-badge {
  font-size: 12px;
  font-weight: 700;
  background: rgba(255,255,255,0.2);
  color: #FFF;
  padding: 4px 14px;
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.15);
}

.month-goal-divider {
  height: 1px;
  background: rgba(255,255,255,0.2);
  margin: 14px 0 10px;
}

.month-goal-item {
  text-align: center;
  flex: 1;
}

.month-goal-item-val {
  font-size: 22px;
  font-weight: 700;
}

.month-goal-item-lbl {
  font-size: 11px;
  opacity: 0.8;
  margin-top: 3px;
}

.month-goals {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-rest {
  background: #F3F4F6;
  color: var(--text-secondary);
}

.day-meta {
  display: flex;
  gap: 6px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.day-meta-item {
  font-size: 11px;
  color: var(--primary);
  background: rgba(255,107,53,0.08);
  padding: 2px 10px;
  border-radius: 4px;
}

.summary-section {
  padding: 0 20px;
  margin-bottom: 20px;
}

.summary-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12px;
  padding-left: 10px;
  border-left: 3px solid var(--primary);
}

.summary-card {
  background: var(--card);
  border-radius: 14px;
  padding: 16px;
  border: 1px solid var(--border);
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-item-val {
  font-size: 18px;
  font-weight: 700;
  color: var(--primary);
}

.summary-item-lbl {
  font-size: 11px;
  color: var(--text-secondary);
  margin-top: 2px;
}

/* === tab-bar bottom padding === */
.page-container { padding-bottom: calc(76px + env(safe-area-inset-bottom)) !important; }
