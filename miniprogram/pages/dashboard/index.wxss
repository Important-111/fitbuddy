/* 仪表盘页 - 补充样式 */

.section-link {
  font-size: 13px;
  color: var(--primary);
}

.progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.progress-row:last-child {
  margin-bottom: 0;
}

.progress-item {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}

.progress-label {
  font-size: 13px;
  color: var(--text-secondary);
  white-space: nowrap;
}

.progress-bar-wrap-sm {
  width: 100px;
  height: 6px;
  background: var(--border);
  border-radius: 3px;
  overflow: hidden;
}

.progress-bar-fill-sm {
  height: 100%;
  background: var(--primary);
  border-radius: 3px;
  transition: width 0.3s ease;
}

.progress-value {
  font-size: 13px;
  color: var(--text-secondary);
  white-space: nowrap;
}

.weight-trend {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10px;
  margin-top: 10px;
  border-top: 1px solid var(--border);
}

.weight-down {
  font-size: 13px;
  color: var(--success);
}
