.phone-auth-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  padding: 48rpx;
  box-sizing: border-box;
}

.phone-auth-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 32rpx;
  width: 100%;
  max-width: 600rpx;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.card-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.close-icon::before,
.close-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 28rpx;
  height: 3rpx;
  background: #9CA3AF;
  border-radius: 2rpx;
}

.close-icon::before {
  transform: rotate(45deg);
}

.close-icon::after {
  transform: rotate(-45deg);
}

.card-icon {
  font-size: 72rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1F2937;
  text-align: center;
  margin-bottom: 20rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
  text-align: justify;
}

.card-list {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.card-list-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-list-item:last-child {
  margin-bottom: 0;
}

.bullet {
  color: #FF6B35;
  font-weight: 700;
  margin-right: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.bullet-text {
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.5;
  flex: 1;
}

.agree-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
  background: #FFFFFF;
  transition: all 0.2s;
}

.check-box.checked {
  background: #FF6B35;
  border-color: #FF6B35;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.agree-text {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  flex: 1;
}

.link {
  color: #FF6B35;
  font-weight: 500;
}

.card-btn-primary {
  width: 100%;
  height: 88rpx;
  background: #FF6B35;
  color: #FFFFFF;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  line-height: 88rpx;
}

.card-btn-primary::after {
  border: none;
}

.card-btn-primary.disabled {
  background: #D1D5DB;
  color: #FFFFFF;
}

.card-btn-secondary {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}

.card-tip {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.5;
}
