.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(56px + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--card, #FFF);
  border-top: 1px solid var(--border, #EEE);
  display: flex;
  align-items: stretch;
  z-index: 1000;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6px 0 4px;
  gap: 2px;
}
.tab-icon {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tab-label {
  font-size: 10px;
  font-weight: 400;
  color: var(--text-secondary, #999);
  line-height: 1;
}
.tab-item.active .tab-label {
  color: var(--primary, #FF6B35);
  font-weight: 600;
}

/* === SVG-like icons via CSS === */
.icon-svg {
  width: 22px;
  height: 22px;
  position: relative;
}

/* 首页 - 房子 */
.icon-house {
  position: absolute;
  inset: 0;
  background: transparent;
}
.icon-house::before {
  content: '';
  position: absolute;
  top: 6px;
  left: 3px;
  right: 3px;
  bottom: 4px;
  border: 1.6px solid var(--text-secondary, #999);
  border-top: none;
  border-radius: 1px;
}
.icon-house::after {
  content: '';
  position: absolute;
  top: 2px;
  left: 0;
  right: 0;
  height: 6px;
  border-left: 11px solid transparent;
  border-right: 11px solid transparent;
  border-bottom: 5px solid var(--text-secondary, #999);
}
.tab-item.active .icon-house.filled::after {
  border-bottom-color: var(--primary, #FF6B35);
}
.tab-item.active .icon-house.filled::before {
  border-color: var(--primary, #FF6B35);
}

/* 训练 - 哑铃 */
.icon-dumbbell {
  position: absolute;
  inset: 0;
}
.icon-dumbbell .bar {
  position: absolute;
  top: 10px;
  left: 4px;
  right: 4px;
  height: 2px;
  background: var(--text-secondary, #999);
}
.icon-dumbbell .weight {
  position: absolute;
  top: 6px;
  width: 4px;
  height: 10px;
  background: var(--text-secondary, #999);
  border-radius: 1px;
}
.icon-dumbbell .weight.left { left: 2px; }
.icon-dumbbell .weight.right { right: 2px; }
.icon-dumbbell .weight.left::before,
.icon-dumbbell .weight.right::before {
  content: '';
  position: absolute;
  top: -2px;
  left: -2px;
  right: -2px;
  height: 14px;
  background: inherit;
  border-radius: 1px;
}
.tab-item.active .icon-dumbbell.filled .bar,
.tab-item.active .icon-dumbbell.filled .weight {
  background: var(--primary, #FF6B35);
}

/* 进度 - 柱状图 */
.icon-chart {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 2px;
  padding-bottom: 3px;
}
.icon-chart .chart-bar {
  width: 4px;
  background: var(--text-secondary, #999);
  border-radius: 1px 1px 0 0;
}
.icon-chart .chart-bar.b1 { height: 6px; }
.icon-chart .chart-bar.b2 { height: 10px; }
.icon-chart .chart-bar.b3 { height: 14px; }
.tab-item.active .icon-chart.filled .chart-bar {
  background: var(--primary, #FF6B35);
}

/* 饮食 - 盘子 */
.icon-plate {
  position: absolute;
  inset: 4px;
  border: 2px solid var(--text-secondary, #999);
  border-radius: 50%;
}
.icon-plate .plate-inner {
  position: absolute;
  inset: 4px;
  border: 1.5px solid var(--text-secondary, #999);
  border-radius: 50%;
}
.tab-item.active .icon-plate.filled,
.tab-item.active .icon-plate.filled .plate-inner {
  border-color: var(--primary, #FF6B35);
}

/* 我的 - 用户 */
.icon-user {
  position: absolute;
  inset: 0;
}
.icon-user .user-head {
  position: absolute;
  top: 3px;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 6px;
  border: 1.6px solid var(--text-secondary, #999);
  border-radius: 50%;
}
.icon-user .user-body {
  position: absolute;
  bottom: 3px;
  left: 50%;
  transform: translateX(-50%);
  width: 12px;
  height: 6px;
  border: 1.6px solid var(--text-secondary, #999);
  border-bottom: none;
  border-radius: 6px 6px 0 0;
}
.tab-item.active .icon-user.filled .user-head,
.tab-item.active .icon-user.filled .user-body {
  border-color: var(--primary, #FF6B35);
}
